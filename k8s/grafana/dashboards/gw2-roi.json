{
  "uid": "gw2-craft-roi",
  "title": "GW2 Crafting ROI",
  "tags": ["gw2", "trading"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Candidates passing gates",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Best ROI %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT max(roi_pct) AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last updated",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT (extract(epoch FROM max(updated_at)) * 1000)::bigint AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Learnable candidates",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS value FROM craft_roi_learnable;"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top craftable items by ROI (craft-and-list)",
      "gridPos": { "h": 24, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT output_item_name AS item, fmt_coin(profit) || ' (' || round(roi_pct::numeric, 1) || '%)' AS profit, fmt_coin(craft_cost) AS craft_cost, fmt_coin(list_revenue) AS list_revenue, fmt_coin(instant_sell_revenue) AS instant_sell, sell_sold_1d || ' in ' || round(days_to_sell::numeric, 2) || 'd' AS demand, output_item_id AS item_id FROM craft_roi ORDER BY roi_pct DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "item" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in GW2Efficiency crafting calculator",
                    "url": "https://gw2efficiency.com/crafting/calculator/a~1!b~1!c~1!d~1-${__data.fields.item_id}!e~0!f~1",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "item_id" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "sortBy": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Learnable recipes (not yet known) — free discovery first, then buyable sheets",
      "gridPos": { "h": 24, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT output_item_name AS item, learn_method AS learn, fmt_coin(profit) || ' (' || round(roi_pct::numeric, 1) || '%)' AS profit, sell_sold_1d || ' in ' || round(days_to_sell::numeric, 2) || 'd' AS demand, (CASE WHEN learn_method = 'BUY' THEN 'https://wiki.guildwars2.com/wiki/Recipe:%20' || replace(replace(output_item_name, '''', '%27'), ' ', '%20') ELSE 'https://gw2efficiency.com/crafting/calculator/a~1!b~1!c~1!d~1-' || output_item_id || '!e~0!f~1' END) AS link FROM craft_roi_learnable ORDER BY (learn_method = 'BUY'), roi_pct DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "item" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "BUY → wiki recipe sheet (vendor & currency); DISCOVER → GW2Efficiency calculator",
                    "url": "${__data.fields.link:raw}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "link" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": { "sortBy": [] }
    }
  ]
}
