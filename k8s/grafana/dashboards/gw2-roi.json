{
  "uid": "gw2-craft-roi",
  "title": "GW2 Crafting ROI",
  "tags": ["gw2", "trading"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Candidates passing gates",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Best ROI %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT max(roi_pct) AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last updated",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT max(updated_at) AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top craftable items by ROI (craft-and-list)",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT output_item_name AS item, output_item_count AS qty, round(roi_pct::numeric, 1) AS roi_pct, (CASE WHEN profit < 0 THEN '-' ELSE '' END || (abs(profit)/10000) || 'g ' || ((abs(profit)%10000)/100) || 's ' || (abs(profit)%100) || 'c') AS profit, ((craft_cost/10000) || 'g ' || ((craft_cost%10000)/100) || 's ' || (craft_cost%100) || 'c') AS craft_cost, ((list_revenue/10000) || 'g ' || ((list_revenue%10000)/100) || 's ' || (list_revenue%100) || 'c') AS list_revenue, round(optimal_roi_pct::numeric, 1) AS optimal_roi_pct, ((instant_sell_revenue/10000) || 'g ' || ((instant_sell_revenue%10000)/100) || 's ' || (instant_sell_revenue%100) || 'c') AS instant_sell, sell_sold_1d, round(days_to_sell::numeric, 2) AS days_to_sell FROM craft_roi ORDER BY roi_pct DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "item" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Search on GW2Efficiency",
                    "url": "https://gw2efficiency.com/tradingpost?filter.search.term=${__data.fields.item:percentencode}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "roi_pct" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byName", "options": "optimal_roi_pct" },
            "properties": [{ "id": "unit", "value": "percent" }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "roi_pct", "desc": true }]
      }
    }
  ]
}
