{
  "uid": "gw2-craft-roi",
  "title": "GW2 Crafting ROI",
  "tags": ["gw2", "trading"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-90d", "to": "now" },
  "panels": [
    {
      "id": 7,
      "type": "timeseries",
      "title": "Trading post — cumulative bought vs sold vs net (gold)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT purchased_at AS time, sum(CASE WHEN kind='buy' THEN price*quantity ELSE 0 END) OVER (ORDER BY purchased_at) / 10000.0 AS bought, sum(CASE WHEN kind='sell' THEN price*quantity ELSE 0 END) OVER (ORDER BY purchased_at) / 10000.0 AS sold, sum(CASE WHEN kind='sell' THEN price*quantity ELSE -price*quantity END) OVER (ORDER BY purchased_at) / 10000.0 AS net FROM tp_transactions ORDER BY purchased_at;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "spanNulls": true } } },
      "options": { "tooltip": { "mode": "multi", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Best ROI %",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT max(roi_pct) AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last updated",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT (extract(epoch FROM max(updated_at)) * 1000)::bigint AS value FROM craft_roi;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top craftable items by ROI (craft-and-list)",
      "gridPos": { "h": 28, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT output_item_name AS item, fmt_coin(profit) || ' (' || round(roi_pct::numeric, 1) || '%)' AS profit, sell_sold_1d || ' in ' || round(days_to_sell::numeric, 2) || 'd' AS demand, output_item_id AS item_id FROM craft_roi ORDER BY roi_pct DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "item" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in GW2Efficiency crafting calculator",
                    "url": "https://gw2efficiency.com/crafting/calculator/a~1!b~1!c~1!d~1-${__data.fields.item_id}!e~0!f~1",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "item_id" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": {
        "sortBy": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Recipes to buy (unlearned sheets), by ROI",
      "gridPos": { "h": 24, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "gw2-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT output_item_name AS item, fmt_coin(profit) || ' (' || round(roi_pct::numeric, 1) || '%)' AS profit, sell_sold_1d || ' in ' || round(days_to_sell::numeric, 2) || 'd' AS demand, 'https://wiki.guildwars2.com/wiki/Recipe:%20' || replace(replace(output_item_name, '''', '%27'), ' ', '%20') AS link FROM craft_roi_learnable ORDER BY roi_pct DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "item" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "GW2 Wiki — recipe sheet: vendor & currency",
                    "url": "${__data.fields.link:raw}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "link" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          }
        ]
      },
      "options": { "sortBy": [] }
    }
  ]
}
